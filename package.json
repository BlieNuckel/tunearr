{
  "name": "tunearr",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "type": "module",
  "dependencies": {
    "@floating-ui/react-dom": "^2.1.8",
    "@heroicons/react": "^2.2.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "better-sqlite3": "^12.11.1",
    "concurrently": "^9.2.3",
    "express": "^5.2.1",
    "multer": "^2.2.0",
    "node-cache": "^5.1.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.30",
    "undici": "^7.28.0",
    "web-haptics": "^0.0.6",
    "web-vitals": "^5.3.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "scripts": {
    "dev": "concurrently \"vite\" \"tsx --tsconfig server/tsconfig.json server/index.ts\"",
    "start": "concurrently \"vite\" \"tsx --tsconfig server/tsconfig.json server/index.ts\"",
    "start:client": "vite",
    "start:server": "tsx --tsconfig server/tsconfig.json server/index.ts",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit && pnpm run typecheck:server",
    "typecheck:client": "tsc --noEmit",
    "typecheck:server": "cd server && tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run --config vitest.config.ts",
    "test:server": "vitest run --config server/vitest.config.ts",
    "typeorm": "tsx node_modules/typeorm/cli.js",
    "migration:generate": "pnpm typeorm migration:generate -d server/db/dataSource.ts",
    "migration:run": "pnpm typeorm migration:run -d server/db/dataSource.ts",
    "seed": "tsx --tsconfig server/tsconfig.json server/dev/seed.ts",
    "dev:mock": "MOCK_LIDARR=true pnpm dev",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.2.0",
    "@types/node": "^25.9.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^6.0.3",
    "@vitejs/plugin-react": "^5.2.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.16",
    "prettier": "^3.9.4",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^7.3.6",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=22.13.0",
    "pnpm": ">=10.0.0"
  }
}
